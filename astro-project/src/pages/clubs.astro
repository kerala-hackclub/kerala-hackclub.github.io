---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const clubs = [
  {
    name: 'Spark',
    location: 'Kochi',
  },
  {
    name: 'HackTVM',
    location: 'Trivandrum',
  },
  {
    name: 'Great Club',
    location: 'Pathanamthitta',
  }
];
---

<Layout title="Active Clubs" description="View all active Hack Clubs in Kerala.">
  <Navbar />
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
      <div class="max-w-2xl">
        <h1 class="text-5xl font-bold text-slate-900 mb-6">Active Clubs</h1>
        <p class="text-xl text-slate-600">
          Discover the vibrant hack clubs across Kerala. Each club is led by high schoolers, 
          for high schoolers. Find one near you or start your own!
        </p>
      </div>
      <a 
        href="https://apply.hackclub.com/" 
        target="_blank"
        class="inline-flex items-center justify-center px-8 py-4 bg-[#ec3750] text-white rounded-full font-bold text-lg hover:bg-[#d63148] transition-all shadow-xl hover:-translate-y-1 whitespace-nowrap"
      >
        Start Your Own Club
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {clubs.map(club => (
        <div class="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm hover:shadow-md transition-all flex flex-col gap-3">
          <h2 class="text-2xl font-bold text-slate-900">{club.name}</h2>
          <div class="flex">
            <span class="inline-flex items-center px-3 py-1 bg-slate-100 text-slate-600 text-sm font-medium rounded-full">
              <svg class="h-3 w-3 mr-1.5 text-[#ec3750]" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
              </svg>
              {club.location}
            </span>
          </div>
        </div>
      ))}
    </div>
  </main>
  <Footer />
</Layout>
