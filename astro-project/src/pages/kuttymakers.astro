---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const title = "Hack Club Kuttymakers";
const description = "A collaborative movement by Hack Club Kerala and Tinkerspace to encourage youth to jump into the world of programming and hardware.";
---

<Layout title={title} description={description}>
	<Navbar />
	<main class="overflow-hidden">
		<!-- Hero Section -->
		<section class="relative bg-slate-50 py-20 lg:py-32">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
				<div class="text-center">
					<h1 class="text-5xl lg:text-7xl font-bold tracking-tight text-slate-900 mb-6">
						Hack Club Kuttymakers
					</h1>
					<p class="text-xl lg:text-2xl text-slate-600 mb-10 max-w-3xl mx-auto">
A Hack Club initiative at Tinkerspace Kochi to build, tinker, and host your own programming and hardware workshops.						</p>
					
					<!-- Progress Bar Section -->
					<div class="mb-10 max-w-md mx-auto">
						<div class="flex justify-between items-center mb-2">
							<span class="text-sm font-bold text-slate-900 uppercase tracking-wider">Teens Shipping</span>
							<span class="text-sm font-bold text-[#ec3750]">27 / 500</span>
						</div>
						<div class="h-4 w-full bg-slate-200 rounded-full overflow-hidden p-1 shadow-inner">
							<div 
								class="h-full bg-gradient-to-r from-[#ec3750] to-[#ff8c37] rounded-full shadow-[0_0_10px_rgba(236,55,80,0.5)] transition-all duration-1000 ease-out" 
								style="width: 5.4%"
							></div>
						</div>
						<p class="text-xs text-slate-500 mt-2 italic text-center">Join us in reaching our goal of 500 makers!</p>
					</div>

					<div class="flex flex-wrap justify-center gap-4">
						<a href="https://hackclub.com/slack/" target="_blank" class="btn btn-primary text-lg">
							Join the Movement
						</a>
						<a href="#how-it-works" class="btn btn-secondary text-lg">
							Learn More
						</a>
					</div>
				</div>
			</div>
            <!-- Decorative background elements -->
            <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 w-96 h-96 bg-red-100 rounded-full blur-3xl opacity-50"></div>
            <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-96 h-96 bg-blue-100 rounded-full blur-3xl opacity-50"></div>
		</section>

		<!-- How it Works Section -->
		<section id="how-it-works" class="py-20 bg-white">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid lg:grid-cols-2 gap-12 items-center">
					<div>
						<h2 class="text-4xl font-bold text-slate-900 mb-6">How it Works</h2>
						<p class="text-lg text-slate-600 mb-8 leading-relaxed">
							We host Hack Club workshops at Tinkerspace Kochi where you can learn everything from building your first website to soldering electronics. 
						</p>
						<div class="space-y-6">
							<div class="flex gap-4">
								<div class="flex-shrink-0 w-12 h-12 bg-red-100 text-[#ec3750] rounded-2xl flex items-center justify-center font-bold text-xl">1</div>
								<div>
									<h3 class="font-bold text-xl mb-1 text-slate-900">Attend Workshops</h3>
									<p class="text-slate-600">Join our sessions at Tinkerspace and learn by building real projects.</p>
								</div>
							</div>
							<div class="flex gap-4">
								<div class="flex-shrink-0 w-12 h-12 bg-blue-100 text-blue-600 rounded-2xl flex items-center justify-center font-bold text-xl">2</div>
								<div>
									<h3 class="font-bold text-xl mb-1 text-slate-900">Get Rewards & Grants</h3>
									<p class="text-slate-600">The more you build and attend, the more rewards and grants you unlock to fuel your next project.</p>
								</div>
							</div>
							<div class="flex gap-4">
								<div class="flex-shrink-0 w-12 h-12 bg-green-100 text-green-600 rounded-2xl flex items-center justify-center font-bold text-xl">3</div>
								<div>
									<h3 class="font-bold text-xl mb-1 text-slate-900">Ship to Hack Club</h3>
									<p class="text-slate-600">Showcase your hardware or software creations to the global Hack Club community.</p>
								</div>
							</div>
						</div>
					</div>
					<div class="relative">
						<div class="aspect-square bg-slate-100 rounded-[3rem] overflow-hidden rotate-3 shadow-2xl">
							<img 
								src="/kuttymakers.png" 
								alt="Coding workshop" 
								class="w-full h-full object-cover"
							/>
						</div>
						<div class="absolute -bottom-6 -left-6 aspect-square w-48 bg-[#ec3750] rounded-3xl -rotate-6 flex items-center justify-center p-6 text-white font-bold text-center text-xl shadow-xl">
							Hack Club <br/> Workshops
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Tinkerspace Section -->
		<section class="py-20 bg-slate-50">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
				<h2 class="text-4xl font-bold text-slate-900 mb-6">Hosted at Tinkerspace</h2>
				<p class="text-xl text-slate-600 mb-10 max-w-3xl mx-auto">
					All our workshops are hosted in collaboration with Tinkerspace, a place for makers, hackers, and builders.
				</p>
				<a href="https://leaders.hackclub.com/" target="_blank" class="text-[#ec3750] font-bold text-lg hover:underline inline-flex items-center gap-2">
					Learn more about Hack Club Leaders <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
				</a>
			</div>
		</section>

		<!-- Start a Club CTA -->
		<section class="py-24 bg-white">
			<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="bg-slate-900 rounded-[3rem] p-8 lg:p-16 text-center text-white relative overflow-hidden">
					<div class="relative z-10">
						<h2 class="text-4xl lg:text-5xl font-bold mb-6">Start a Club in Your School</h2>
						<p class="text-xl text-slate-300 mb-10 max-w-2xl mx-auto">
							Take the movement to your campus. Conduct the same workshops and build a local community of makers.
						</p>
						<a href="/clubs" class="btn bg-white text-slate-900 hover:bg-slate-100 text-lg">
							Learn How to Start
						</a>
					</div>
					<!-- Background deco -->
					<div class="absolute top-0 left-0 w-full h-full opacity-10">
						<div class="absolute top-0 right-0 w-64 h-64 bg-white rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
						<div class="absolute bottom-0 left-0 w-64 h-64 bg-[#ec3750] rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>
					</div>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>

<style>
	@reference "../styles/global.css";

	.btn {
		@apply inline-flex items-center justify-center px-8 py-4 rounded-2xl font-bold transition-all duration-200 active:scale-95;
	}
	.btn-primary {
		@apply bg-[#ec3750] text-white hover:bg-[#d63148] shadow-lg hover:shadow-xl;
	}
	.btn-secondary {
		@apply bg-slate-100 text-slate-800 hover:bg-slate-200;
	}
</style>
