<section class="bg-slate-900 text-white py-24 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="text-4xl md:text-5xl font-bold mb-6">Start a Hack Club in Kerala</h2>
        <p class="text-xl text-slate-300 mb-10 leading-relaxed">
          The best way to learn is by doing. Start a club at your school and build a community of makers. 
          We provide the resources, the curriculum, and the community.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a 
            href="https://apply.hackclub.com/" 
            target="_blank" 
            class="inline-flex items-center justify-center px-8 py-4 bg-[#ec3750] text-white rounded-full font-bold text-lg hover:bg-[#d63148] transition-all shadow-xl hover:-translate-y-1"
          >
            Apply to Create a Club
          </a>
          <a 
            href="/clubs" 
            class="inline-flex items-center justify-center px-8 py-4 bg-white text-slate-900 rounded-full font-bold text-lg hover:bg-slate-100 transition-all shadow-xl hover:-translate-y-1"
          >
            View Active Clubs
          </a>
        </div>
      </div>
      <div class="relative group">
        <div class="absolute -inset-4 bg-gradient-to-r from-[#ec3750] to-[#ff8c37] rounded-[2rem] blur-2xl opacity-20 group-hover:opacity-40 transition-opacity"></div>
        <img 
          src="/teens.jpg" 
          alt="Hack Club Community" 
          class="relative rounded-[2rem] shadow-2xl border border-white/10 hover:scale-105 transition-transform duration-500"
        />
      </div>
    </div>
  </div>
  
  <!-- Decorative background elements -->
  <div class="absolute top-0 right-0 w-64 h-64 bg-[#ec3750]/20 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-blue-500/10 rounded-full blur-3xl"></div>
</section>
